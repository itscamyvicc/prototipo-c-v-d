# Email (Gmail)
# Crie uma senha de app em: myaccount.google.com/apppasswords
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=senha_de_app_sem_espacos

# WhatsApp (UltraMsg)
# Crie uma conta em: ultramsg.com
ULTRAMSG_INSTANCE=sua_instancia
ULTRAMSG_TOKEN=seu_token

# Firebase Admin SDK
# Baixe em: Firebase Console → Configurações → Contas de serviço → Gerar nova chave privada
# Salve como serviceAccountKey.json na pasta backend/